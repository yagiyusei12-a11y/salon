generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  STAFF
}

model Tenant {
  id           String        @id @default(cuid())
  name         String
  users        User[]
  customers    Customer[]
  appointments Appointment[]
  serviceMenus ServiceMenu[]
  payments     Payment[]
  auditLogs    AuditLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String
  role         UserRole      @default(STAFF)
  isActive     Boolean       @default(true)
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  payments     Payment[]
  auditLogs    AuditLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Customer {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lastName     String
  firstName    String
  phone        String?
  email        String?
  notes        String?
  tags         String?       // comma-separated tags: VIP,CAUTION,NEW
  lastVisitAt  DateTime?
  appointments Appointment[]
  payments     Payment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([tenantId, createdAt])
}

enum AppointmentStatus {
  BOOKED
  COMPLETED
  CANCELLED
}

model ServiceMenu {
  id               String        @id @default(cuid())
  tenantId         String
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  durationMinutes  Int
  price            Int?
  appointments     Appointment[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([tenantId, createdAt])
}

model Appointment {
  id          String            @id @default(cuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffId     String
  staff       User              @relation(fields: [staffId], references: [id], onDelete: Cascade)
  customerId  String?
  customer    Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  menuId      String?
  menu        ServiceMenu?      @relation(fields: [menuId], references: [id], onDelete: SetNull)
  startAt     DateTime
  endAt       DateTime
  status      AppointmentStatus @default(BOOKED)
  notes       String?
  payment     Payment?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([tenantId, startAt])
  @@index([tenantId, status, startAt])
  @@index([tenantId, staffId, startAt, endAt])
}

enum PaymentMethod {
  CASH
  CARD
  QR
}

model Payment {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointmentId String?       @unique
  appointment   Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  staffId       String?
  staff         User?         @relation(fields: [staffId], references: [id], onDelete: SetNull)
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  amount        Int
  method        PaymentMethod @default(CASH)
  paidAt        DateTime
  note          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([tenantId, paidAt])
  @@index([tenantId, method, paidAt])
  @@index([tenantId, staffId, paidAt])
  @@index([tenantId, customerId, paidAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  targetType String
  targetId   String?
  detail     String?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, targetType, targetId])
}
